# Copy to .env and fill in. .env is gitignored.

# REQUIRED. Used to sign session cookies AND as the KDF input for encrypting
# the LLM API key at rest. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Changing this AFTER first save invalidates every encrypted API key — the
# admin will have to re-enter it from /settings.
NOTEBOOKLM_SECRET=replace-me-with-a-long-random-string

# Optional. Host port the app binds to. Default 8000.
HOST_PORT=8000

# Optional. DEBUG / INFO / WARNING / ERROR. Default INFO.
NOTEBOOKLM_LOG_LEVEL=INFO
